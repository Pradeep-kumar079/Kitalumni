<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Event Gallery</title>
  <style>
    body { font-family: Arial; padding: 20px; background: #f4f4f4; }
    h2 { text-align: center; }
    .gallery { display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; }
    .gallery img, .gallery video { width: 300px; border-radius: 10px; }
  </style>
</head>
<body>

  <h2>Event Gallery</h2>
  <div class="gallery">
    <img src="https://images.unsplash.com/photo-1531058020387-3be344556be6" alt="">
    <img src="https://images.unsplash.com/photo-1558244661-d248897f5f4b" alt="">
    <video controls src="https://www.w3schools.com/html/mov_bbb.mp4"></video>
  </div>

</body>
</html>